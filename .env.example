# ===========================================
# Scent DNA – Supabase environment variables
# ===========================================
#
# 1. Copy this file and name the copy:  .env.local
# 2. Do not commit .env.local (it is in .gitignore).
# 3. Get the values from your Supabase project (see SUPABASE_SETUP.md).
#

# Your Supabase project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (long string from Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===========================================
# AI (OpenAI) – for fragrance collection analysis
# ===========================================
#
# Paste your OpenAI API key here. Get it from: https://platform.openai.com/api-keys
# Used only on the server to analyze uploaded shelf photos (vision) and generate analysis text.
# Do not add NEXT_PUBLIC_ to this key — it must stay server-only.
#
OPENAI_API_KEY=
